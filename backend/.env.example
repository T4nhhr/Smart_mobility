PORT=3000
NODE_ENV=development

# AWS / LocalStack
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566

# DynamoDB Tables
DYNAMODB_VEHICLES_TABLE=Vehicles
DYNAMODB_TELEMETRY_TABLE=Telemetry
DYNAMODB_ROUTES_TABLE=Routes
DYNAMODB_ALERTS_TABLE=Alerts

# Kinesis
KINESIS_STREAM_NAME=telemetry-stream
KINESIS_SHARD_COUNT=2

# Cognito (LocalStack)
COGNITO_USER_POOL_ID=us-east-1_test
COGNITO_CLIENT_ID=test_client_id
COGNITO_REGION=us-east-1
COGNITO_ENDPOINT=http://localstack:4566

# JWT Secret (dev fallback when Cognito is unavailable)
JWT_SECRET=urbanmove-dev-secret-change-in-prod

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3001
